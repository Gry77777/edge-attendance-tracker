{
  "manifest_version": 3,
  "name": "Work Attendance iTab",
  "short_name": "WorkAttendance",
  "version": "1.3.0",
  "description": "打卡与收入统计小标签插件（Edge）",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "工作打卡",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  }
}
